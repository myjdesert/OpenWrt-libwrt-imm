# ==================== 平台目标配置 ====================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_generic=y

# ==================== 设备型号选择 ====================
# 注意：以下所有设备都基于Qualcomm IPQ60xx芯片平台
# 格式：CONFIG_TARGET_DEVICE_<平台>_<芯片>_DEVICE_<品牌>_<型号>=y

# -------- 消费级/家用路由器 --------
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v2=n              # Link NN6000 V2 (运营商定制)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y                       # ZN M2 (兆能)



#====================彻底禁用无线功能====================
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_hostapd-common=n


# ==================== 设备特定包配置 ====================
# 为京东云 RE-CS-02 设备特别添加的软件包
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="luci-app-athena-led luci-i18n-athena-led-zh-cn"
# 说明：京东云设备需要特殊的LED控制应用，以正确控制设备指示灯

# ==================== 内核和驱动配置 ====================
CONFIG_ATH11K_MEM_PROFILE_512M=y               # ath11k WiFi驱动内存配置为512MB模式
                                                # 适用于大多数IPQ60xx设备（内存为512MB）
                                                
CONFIG_NSS_FIRMWARE_VERSION_11_4=y             # 使用NSS（网络子系统）固件版本11.4
                                                # NSS用于硬件加速网络转发

# ==================== 软件包配置 ====================
CONFIG_PACKAGE_luci-app-athena-led=n           # 雅典娜主题LED控制应用（编译为模块）
                                                # =m 表示编译为独立模块，不内置到固件
                                                
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=n    # LED控制应用的中文语言包（编译为模块）
                                                # 用户可在刷机后通过opkg install安装

# ==================== 编译说明 ====================
# 1. 启用 MULTI_PROFILE 后，编译时会为所有标记为 y 的设备生成固件
